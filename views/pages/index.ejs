<%- include('../partials/head') %>
<%- include('../partials/header') %>

<!-- Search Section -->
<div class="mb-8">
  <h1 class="text-4xl font-bold text-gray-800 mb-2">Plan Your Trip</h1>
  <p class="text-gray-600 text-lg">Compare ALL travel options and costs to find the cheapest way to reach any UK destination.</p>
</div>

<!-- Search Bar -->
<div class="mb-6 flex gap-3">
  <input
    type="text"
    id="search-input"
    placeholder="e.g. Incognito, Winchester"
    class="flex-1 px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500"
  />
  <button
    id="search-btn"
    class="px-6 py-3 bg-blue-600 text-white font-semibold rounded-lg hover:bg-blue-700 transition"
  >
    Search
  </button>
</div>

<!-- Search Results -->
<div id="results" class="mb-6 space-y-2"></div>

<!-- Map -->
<div id="map" class="w-full h-96 rounded-lg border border-gray-300 mb-6"></div>

<!-- Save Panel (hidden until a place is selected) -->
<div id="save-panel" class="hidden bg-white p-6 rounded-lg border border-gray-300 shadow-md">
  <h3 class="text-2xl font-bold text-gray-800 mb-4">Save this place</h3>
  <p id="selected-name" class="text-gray-600 text-sm mb-4"></p>

  <div class="mb-4">
    <label class="block text-sm font-medium text-gray-700 mb-2">
      Category (optional)
    </label>
    <input
      type="text"
      id="category-input"
      placeholder="bar, restaurant, hike..."
      class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500"
    />
  </div>

  <div class="mb-6">
    <label class="block text-sm font-medium text-gray-700 mb-2">
      Notes (optional)
    </label>
    <textarea
      id="notes-input"
      rows="3"
      placeholder="Any notes about this place..."
      class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500"
    ></textarea>
  </div>

  <button
    id="save-btn"
    class="w-full px-6 py-3 bg-blue-600 text-white font-semibold rounded-lg hover:bg-blue-700 transition"
  >
    Save to "Places to Go"
  </button>
  <p id="save-msg" class="text-center mt-4 text-sm font-medium"></p>
</div>

<!-- Browser-side JavaScript for map and search -->
<script src="/js/map.js"></script>

<%- include('../partials/footer') %>